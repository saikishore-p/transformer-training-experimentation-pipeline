# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# ML artifacts (can be large / machine-specific)
mlruns/
checkpoints/

# Sweep output files written by run_sweep.py
sweep_results*.json

# Ray temporary files (worker logs, spill storage, dashboard data)
/tmp/ray/
ray_spill/

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# Test coverage
.coverage
htmlcov/
.pytest_cache/

# uv / hatch build cache
.cache/
*.dist-info/

# Jupyter notebooks (if you experiment interactively)
.ipynb_checkpoints/
*.ipynb

# Secrets / local env overrides (never commit these)
.env
.env.local
